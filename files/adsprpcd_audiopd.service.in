[Unit]
Description=audiopd aDSP RPC daemon
After=dev-fastrpc\x2dadsp.device dev-fastrpc\x2dadsp\x2dsecure.device
ConditionPathExists=|/dev/fastrpc-adsp
ConditionPathExists=|/dev/fastrpc-adsp-secure

[Service]
Type=exec
ExecStart=@sbindir@/adsprpcd audiopd
Restart=on-failure
RestartSec=5
RestartPreventExitStatus=2  # AEE_ENOMEMORY
RestartForceExitStatus=SIGTERM
