[Unit]
Description=gDSP RPC daemon
After=dev-fastrpc\x2dgdsp1.device dev-fastrpc\x2dgdsp1\x2dsecure.device
ConditionPathExists=|/dev/fastrpc-gdsp1
ConditionPathExists=|/dev/fastrpc-gdsp1-secure

[Service]
Type=exec
ExecStart=/usr/bin/gdsprpcd rootpd gdsp1
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
